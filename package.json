{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "generate": "prisma generate",
    "db": "prisma db push && npm run billshield:invariants",
    "billshield:invariants": "prisma db execute --file prisma/sql/billshield_invariants.sql",
    "lint": "eslint ./src --fix",
    "build": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc --build",
    "seed": "prisma db seed",
    "build:linux": "rm -rf dist && tsc --build",
    "start": "npx tsx src/index.ts",
    "dev": "nodemon --exec \"node --max-old-space-size=4096 -r ts-node/register/transpile-only src/index.ts\" --watch src --watch .env --ext ts,env",
    "dev:start": "bash ./dev_start.sh",
    "dev:stop": "bash ./dev_stop.sh"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itax-easy/node-api.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/itax-easy/node-api/issues"
  },
  "homepage": "https://github.com/itax-easy/node-api#readme",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcrypt": "^5.0.0",
    "archiver": "^7.0.1",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.1.0",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.6.1",
    "emailjs": "^4.0.3",
    "express": "^4.21.2",
    "express-rate-limit": "^6.7.0",
    "googleapis": "^144.0.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.11.5",
    "nodemailer": "^6.10.1",
    "pdf-lib": "^1.17.1",
    "pdf-merger-js": "^2.0.1",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^24.10.2",
    "razorpay": "^2.9.5",
    "redis": "^4.7.1",
    "scraper": "^0.0.9",
    "sharp": "^0.33.5",
    "tesseract.js": "^5.1.0",
    "tsx": "^4.19.2",
    "uuid": "^9.0.1",
    "zod": "^3.25.76",
    "zod-error": "^1.5.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.25",
    "@types/nodemailer": "^7.0.10",
    "@types/redis": "^4.0.11",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.46.0",
    "nodemon": "^3.1.11",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.17 <=22"
